# For `npm run dev` on the host against `docker compose up -d db`, use localhost:
# DATABASE_URL="postgresql://nudge:nudge@localhost:5432/nudge?schema=public"
# For the full Docker Compose stack (app + db together), use the service name:
DATABASE_URL="postgresql://nudge:nudge@db:5432/nudge?schema=public"

# Postgres container init vars -- must stay consistent with DATABASE_URL above
POSTGRES_USER=nudge
POSTGRES_PASSWORD=nudge
POSTGRES_DB=nudge

# The shared passphrase, in plain text.
APP_PASSPHRASE=

# Random signing secret for session JWTs, generate with:
# openssl rand -base64 32
SESSION_SECRET=

# Anthropic API key, used for the category-suggestion call
ANTHROPIC_API_KEY=
